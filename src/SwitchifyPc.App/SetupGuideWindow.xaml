<Window x:Class="SwitchifyPc.App.SetupGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:SwitchifyPc.Core.Ui;assembly=SwitchifyPc.Core"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:chrome="clr-namespace:SwitchifyPc.App.Chrome"
        mc:Ignorable="d"
        Title="Set up Switchify PC"
        Width="820"
        Height="620"
        MinWidth="760"
        MinHeight="560"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ChromeBackground}"
        FontFamily="Segoe UI"
        Icon="Assets/icon.ico"
        d:DataContext="{d:DesignInstance Type=ui:SetupGuideViewModel, IsDesignTimeCreatable=True}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="Foreground" Value="{DynamicResource Text}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                MinHeight="{TemplateBinding MinHeight}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BrandPrimary}" />
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceMuted}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="BorderBrush" Value="{DynamicResource BrandPrimary}" />
            <Setter Property="Background" Value="{DynamicResource BrandPrimary}" />
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="LineHeight" Value="21" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <chrome:SwitchifyTitleBar Grid.Row="0"
                                  TitleText="Set up Switchify PC"
                                  ShowMinimizeButton="True" />

        <Grid Grid.Row="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Setup guide"
                               Foreground="{DynamicResource ChromeForeground}"
                               FontSize="12"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,5,0,0"
                               Text="Connect Switchify for Android"
                               Foreground="{DynamicResource ChromeForeground}"
                               FontSize="25"
                               FontWeight="Bold" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="{Binding StepProgress}"
                           Foreground="{DynamicResource ChromeForeground}"
                           FontWeight="Bold" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,24,0,24">
                <Border Style="{StaticResource Panel}"
                        Visibility="{Binding IsBluetoothStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Check Bluetooth"
                                   Foreground="{DynamicResource Text}"
                                   FontSize="21"
                                   FontWeight="Bold" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="Switchify uses nearby Bluetooth Low Energy to connect directly to your Android device."
                                   Style="{StaticResource MutedText}" />
                        <Border Margin="0,22,0,0"
                                Padding="18"
                                Background="{DynamicResource SurfaceMuted}"
                                CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="{Binding BluetoothSetupTitle}"
                                           Foreground="{DynamicResource Text}"
                                           FontSize="17"
                                           FontWeight="Bold" />
                                <TextBlock Margin="0,7,0,0"
                                           Text="{Binding BluetoothSetupBody}"
                                           Style="{StaticResource MutedText}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Panel}"
                        Visibility="{Binding IsAndroidAppStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Get Switchify for Android"
                                       Foreground="{DynamicResource Text}"
                                       FontSize="21"
                                       FontWeight="Bold" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Install the Android app from Google Play, then open it near this PC."
                                       Style="{StaticResource MutedText}" />
                            <Button Margin="0,20,0,0"
                                    HorizontalAlignment="Left"
                                    Content="Open Google Play"
                                    Click="OpenAndroidDownload_Click" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Margin="28,0,4,0"
                                Padding="10"
                                Background="{DynamicResource SurfaceMuted}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Image Width="164"
                                   Height="164"
                                   Source="Assets/android-download-qr.png"
                                   Stretch="Uniform" />
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource Panel}"
                        Visibility="{Binding IsPairDeviceStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Pair securely"
                                       Foreground="{DynamicResource Text}"
                                       FontSize="21"
                                       FontWeight="Bold" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Confirm that the device name and verification code match before accepting."
                                       Style="{StaticResource MutedText}" />
                            <Border Margin="0,18,0,0"
                                    Padding="14"
                                    Background="{DynamicResource SurfaceMuted}"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding PairingStatusTitle}"
                                               Foreground="{DynamicResource Text}"
                                               FontWeight="Bold" />
                                    <TextBlock Margin="0,5,0,0"
                                               Text="{Binding PairingStatusBody}"
                                               Style="{StaticResource MutedText}" />
                                </StackPanel>
                            </Border>
                            <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding PairingApprovals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="14"
                                                BorderBrush="{DynamicResource BrandPrimary}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DeviceName}"
                                                               Foreground="{DynamicResource Text}"
                                                               FontWeight="Bold" />
                                                    <TextBlock Margin="0,5,0,0"
                                                               Text="{Binding VerificationCode, StringFormat=Verification code {0}}"
                                                               Foreground="{DynamicResource Text}"
                                                               FontWeight="Bold" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Tag="{Binding RequestId}"
                                                            Content="Accept"
                                                            Style="{StaticResource PrimaryButton}"
                                                            Click="AcceptPairing_Click" />
                                                    <Button Margin="8,0,0,0"
                                                            Tag="{Binding RequestId}"
                                                            Content="Reject"
                                                            Click="RejectPairing_Click" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Style="{StaticResource Panel}"
                        Visibility="{Binding IsStartupStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Start with Windows"
                                   Foreground="{DynamicResource Text}"
                                   FontSize="21"
                                   FontWeight="Bold" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="Switchify PC can stay ready in the tray whenever you sign in."
                                   Style="{StaticResource MutedText}" />
                        <Border Margin="0,22,0,0"
                                Padding="18"
                                Background="{DynamicResource SurfaceMuted}"
                                CornerRadius="10">
                            <StackPanel>
                                <CheckBox Content="Start with system"
                                          Foreground="{DynamicResource Text}"
                                          FontWeight="Bold"
                                          IsEnabled="{Binding StartWithSystemSupported}"
                                          IsChecked="{Binding StartWithSystem, Mode=OneWay}"
                                          Click="StartWithSystem_Click" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding StartWithSystemMessage}"
                                           Style="{StaticResource MutedText}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button HorizontalAlignment="Left"
                        Content="Skip for now"
                        Click="Skip_Click" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Back"
                            IsEnabled="{Binding CanGoBack}"
                            Click="Back_Click" />
                    <Button Margin="8,0,0,0"
                            Content="{Binding NextButtonText}"
                            IsEnabled="{Binding CanGoNext}"
                            Style="{StaticResource PrimaryButton}"
                            Click="Next_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
