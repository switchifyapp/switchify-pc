<Window x:Class="SwitchifyPc.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:SwitchifyPc.Core.Ui;assembly=SwitchifyPc.Core"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:chrome="clr-namespace:SwitchifyPc.App.Chrome"
        mc:Ignorable="d"
        Title="Switchify PC settings"
        MinHeight="560"
        MinWidth="760"
        Height="690"
        Width="900"
        ResizeMode="NoResize"
        Icon="Assets/icon.ico"
        FontFamily="Segoe UI"
        Background="{DynamicResource ChromeBackground}"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=ui:SettingsViewModel, IsDesignTimeCreatable=True}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="Foreground" Value="{DynamicResource Text}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                MinHeight="{TemplateBinding MinHeight}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BrandPrimary}" />
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceMuted}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandPrimary}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BrandPrimary}" />
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                MinHeight="{TemplateBinding MinHeight}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BrandPrimaryHover}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BrandPrimaryHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="SubtlePanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text}" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="LineHeight" Value="19" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Text}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="NavRadio" TargetType="RadioButton">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="{DynamicResource Text}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                MinHeight="{TemplateBinding MinHeight}"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceMuted}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Surface}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BrandPrimary}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrandPrimary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentRadio" TargetType="RadioButton">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Text}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                MinHeight="{TemplateBinding MinHeight}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BrandPrimary}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SegmentSelectedBackground}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BrandPrimary}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrandPrimary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="MinWidth" Value="10" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="10" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Foreground" Value="{DynamicResource BrandPrimary}" />
            <Setter Property="Background" Value="{DynamicResource BorderColor}" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource ChromeBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <chrome:SwitchifyTitleBar Grid.Row="0"
                                  TitleText="Switchify PC settings"
                                  ShowMinimizeButton="True" />

        <Border Grid.Row="1"
                Grid.RowSpan="2"
                Margin="0,80,0,0"
                Background="{DynamicResource AppBackground}" />

        <StackPanel Grid.Row="1" Margin="24,24,24,0">
            <TextBlock Text="Settings"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{DynamicResource ChromeForeground}" />
            <TextBlock Margin="0,4,0,18"
                       Text="Tune how Switchify starts, connects, and controls this PC."
                       Foreground="{DynamicResource ChromeSubtleForeground}"
                       Style="{StaticResource MutedText}" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="8"
                    VerticalAlignment="Top">
                <StackPanel>
                    <RadioButton Content="General"
                                 GroupName="SettingsSections"
                                 IsChecked="True"
                                 Style="{StaticResource NavRadio}"
                                 Tag="general"
                                 Checked="SectionNav_Checked" />
                    <RadioButton Content="Pointer and cursor"
                                 GroupName="SettingsSections"
                                 Style="{StaticResource NavRadio}"
                                 Tag="pointer"
                                 Checked="SectionNav_Checked" />
                    <RadioButton Content="Updates"
                                 GroupName="SettingsSections"
                                 Style="{StaticResource NavRadio}"
                                 Tag="updates"
                                 Checked="SectionNav_Checked" />
                    <RadioButton Content="Privacy"
                                 GroupName="SettingsSections"
                                 Style="{StaticResource NavRadio}"
                                 Tag="privacy"
                                 Checked="SectionNav_Checked" />
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="2"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <Grid>
                    <StackPanel x:Name="GeneralPanel">
                        <Border Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="General" Style="{StaticResource SectionTitle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="Control startup behavior and saved Android devices."
                                           Style="{StaticResource MutedText}" />

                                <Border Margin="0,16,0,0" Style="{StaticResource SubtlePanel}">
                                    <StackPanel>
                                        <CheckBox Content="Start with system"
                                                  Click="StartWithSystem_Click"
                                                  IsChecked="{Binding StartWithSystem, Mode=OneWay}"
                                                  IsEnabled="{Binding StartWithSystemSupported}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding StartWithSystemMessage}"
                                                   Style="{StaticResource MutedText}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,14,0,0" Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="Paired devices" Style="{StaticResource SectionTitle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding PairedDevicesMessage}"
                                           Style="{StaticResource MutedText}" />
                                <ItemsControl Margin="0,14,0,0"
                                              ItemsSource="{Binding PairedDevices}"
                                              Visibility="{Binding HasPairedDevices, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Style="{StaticResource SubtlePanel}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DeviceName}"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource Text}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Text="{Binding LastSeenAt, StringFormat=Last seen {0}}"
                                                                   Style="{StaticResource MutedText}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Margin="16,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Tag="{Binding DeviceId}"
                                                            Click="ForgetPairedDevice_Click"
                                                            Content="Forget" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="PointerPanel" Visibility="Collapsed">
                        <Border Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="Pointer and cursor" Style="{StaticResource SectionTitle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="Tune pointer speed and the visual cursor marker used while controlling this PC."
                                           Style="{StaticResource MutedText}" />

                                <Border Margin="0,16,0,0" Style="{StaticResource SubtlePanel}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Pointer speed" Style="{StaticResource DetailLabel}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="Choose how quickly Android pointer movement moves on this display."
                                                           Style="{StaticResource MutedText}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Margin="16,0,0,0"
                                                       VerticalAlignment="Top"
                                                       Text="{Binding PointerScalePercent, StringFormat={}{0:0}%}"
                                                       Style="{StaticResource DetailValue}" />
                                        </Grid>

                                        <UniformGrid Margin="0,14,0,0" Columns="5">
                                            <RadioButton Content="5%"
                                                         GroupName="PointerScale"
                                                         IsChecked="{Binding IsPointerScale5, Mode=OneWay}"
                                                         Checked="PointerScale5_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                            <RadioButton Content="25%"
                                                         GroupName="PointerScale"
                                                         IsChecked="{Binding IsPointerScale25, Mode=OneWay}"
                                                         Checked="PointerScale25_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                            <RadioButton Content="50%"
                                                         GroupName="PointerScale"
                                                         IsChecked="{Binding IsPointerScale50, Mode=OneWay}"
                                                         Checked="PointerScale50_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                            <RadioButton Content="75%"
                                                         GroupName="PointerScale"
                                                         IsChecked="{Binding IsPointerScale75, Mode=OneWay}"
                                                         Checked="PointerScale75_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                            <RadioButton Content="100%"
                                                         GroupName="PointerScale"
                                                         IsChecked="{Binding IsPointerScale100, Mode=OneWay}"
                                                         Checked="PointerScale100_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                        </UniformGrid>

                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Margin="0,0,8,0" Style="{StaticResource PanelBorder}" Padding="12">
                                                <StackPanel>
                                                    <TextBlock Text="Small" Style="{StaticResource DetailLabel}" />
                                                    <TextBlock Margin="0,4,0,0" Text="{Binding PointerSmall}" Style="{StaticResource DetailValue}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource PanelBorder}" Padding="12">
                                                <StackPanel>
                                                    <TextBlock Text="Medium" Style="{StaticResource DetailLabel}" />
                                                    <TextBlock Margin="0,4,0,0" Text="{Binding PointerMedium}" Style="{StaticResource DetailValue}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Padding="12">
                                                <StackPanel>
                                                    <TextBlock Text="Large" Style="{StaticResource DetailLabel}" />
                                                    <TextBlock Margin="0,4,0,0" Text="{Binding PointerLarge}" Style="{StaticResource DetailValue}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,14,0,0" Style="{StaticResource SubtlePanel}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Mouse repeat" Style="{StaticResource DetailLabel}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="Repeat mouse movement and scrolling until the next switch press."
                                                           Style="{StaticResource MutedText}" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      Margin="16,0,0,0"
                                                      VerticalAlignment="Top"
                                                      Content="Enabled"
                                                      Click="MouseRepeatEnabled_Click"
                                                      IsChecked="{Binding MouseRepeatEnabled, Mode=OneWay}" />
                                        </Grid>

                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Movement repeat interval" Style="{StaticResource DetailLabel}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="Time between repeated pointer movements."
                                                           Style="{StaticResource MutedText}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Margin="16,0,0,0"
                                                       VerticalAlignment="Top"
                                                       Text="{Binding MouseRepeatMoveInterval}"
                                                       Style="{StaticResource DetailValue}" />
                                        </Grid>

                                        <UniformGrid Margin="0,14,0,0" Columns="4"
                                                     IsEnabled="{Binding MouseRepeatEnabled}">
                                            <RadioButton Content="0.1 s"
                                                         GroupName="MouseRepeatMoveInterval"
                                                         IsChecked="{Binding IsMouseRepeatMoveInterval100, Mode=OneWay}"
                                                         Checked="MouseRepeatMoveInterval100_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                            <RadioButton Content="0.25 s"
                                                         GroupName="MouseRepeatMoveInterval"
                                                         IsChecked="{Binding IsMouseRepeatMoveInterval250, Mode=OneWay}"
                                                         Checked="MouseRepeatMoveInterval250_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                            <RadioButton Content="0.5 s"
                                                         GroupName="MouseRepeatMoveInterval"
                                                         IsChecked="{Binding IsMouseRepeatMoveInterval500, Mode=OneWay}"
                                                         Checked="MouseRepeatMoveInterval500_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                            <RadioButton Content="1 s"
                                                         GroupName="MouseRepeatMoveInterval"
                                                         IsChecked="{Binding IsMouseRepeatMoveInterval1000, Mode=OneWay}"
                                                         Checked="MouseRepeatMoveInterval1000_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                        </UniformGrid>

                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock Text="Movement acceleration" Style="{StaticResource DetailLabel}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="Gradually increase repeated movement to the selected pointer speed."
                                                       Style="{StaticResource MutedText}" />
                                        </StackPanel>

                                        <UniformGrid Margin="0,14,0,0" Columns="4"
                                                     IsEnabled="{Binding MouseRepeatEnabled}">
                                            <RadioButton Content="Off"
                                                         GroupName="MouseRepeatAcceleration"
                                                         IsChecked="{Binding IsMouseRepeatAccelerationOff, Mode=OneWay}"
                                                         Checked="MouseRepeatAccelerationOff_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                            <RadioButton Content="Short"
                                                         GroupName="MouseRepeatAcceleration"
                                                         IsChecked="{Binding IsMouseRepeatAccelerationShort, Mode=OneWay}"
                                                         Checked="MouseRepeatAccelerationShort_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                            <RadioButton Content="Medium"
                                                         GroupName="MouseRepeatAcceleration"
                                                         IsChecked="{Binding IsMouseRepeatAccelerationMedium, Mode=OneWay}"
                                                         Checked="MouseRepeatAccelerationMedium_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                            <RadioButton Content="Long"
                                                         GroupName="MouseRepeatAcceleration"
                                                         IsChecked="{Binding IsMouseRepeatAccelerationLong, Mode=OneWay}"
                                                         Checked="MouseRepeatAccelerationLong_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                        </UniformGrid>

                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Scroll repeat interval" Style="{StaticResource DetailLabel}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="Time between repeated scroll actions."
                                                           Style="{StaticResource MutedText}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Margin="16,0,0,0"
                                                       VerticalAlignment="Top"
                                                       Text="{Binding MouseRepeatScrollInterval}"
                                                       Style="{StaticResource DetailValue}" />
                                        </Grid>

                                        <UniformGrid Margin="0,14,0,0" Columns="4"
                                                     IsEnabled="{Binding MouseRepeatEnabled}">
                                            <RadioButton Content="0.1 s"
                                                         GroupName="MouseRepeatScrollInterval"
                                                         IsChecked="{Binding IsMouseRepeatScrollInterval100, Mode=OneWay}"
                                                         Checked="MouseRepeatScrollInterval100_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                            <RadioButton Content="0.25 s"
                                                         GroupName="MouseRepeatScrollInterval"
                                                         IsChecked="{Binding IsMouseRepeatScrollInterval250, Mode=OneWay}"
                                                         Checked="MouseRepeatScrollInterval250_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                            <RadioButton Content="0.5 s"
                                                         GroupName="MouseRepeatScrollInterval"
                                                         IsChecked="{Binding IsMouseRepeatScrollInterval500, Mode=OneWay}"
                                                         Checked="MouseRepeatScrollInterval500_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                            <RadioButton Content="1 s"
                                                         GroupName="MouseRepeatScrollInterval"
                                                         IsChecked="{Binding IsMouseRepeatScrollInterval1000, Mode=OneWay}"
                                                         Checked="MouseRepeatScrollInterval1000_Checked"
                                                         Style="{StaticResource SegmentRadio}" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,14,0,0" Style="{StaticResource SubtlePanel}">
                                    <StackPanel>
                                        <TextBlock Text="Cursor overlay" Style="{StaticResource DetailLabel}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="Control when the overlay appears, how large it is, and the color it uses."
                                                   Style="{StaticResource MutedText}" />

                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Overlay" Style="{StaticResource DetailLabel}" />
                                            <CheckBox Grid.Row="0" Grid.Column="1"
                                                      Content="Show cursor overlay"
                                                      Click="CursorOverlayEnabled_Click"
                                                      IsChecked="{Binding CursorOverlayEnabled, Mode=OneWay}" />

                                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,14,0,0" Text="Visibility" Style="{StaticResource DetailLabel}" />
                                            <UniformGrid Grid.Row="1" Grid.Column="1" Margin="0,14,0,0" Columns="2">
                                                <RadioButton Content="On input"
                                                             GroupName="CursorOverlayVisibility"
                                                             IsChecked="{Binding IsCursorOverlayVisibilityOnInput, Mode=OneWay}"
                                                             Checked="CursorOverlayVisibilityOnInput_Checked"
                                                             Style="{StaticResource SegmentRadio}" />
                                                <RadioButton Content="While controlling"
                                                             GroupName="CursorOverlayVisibility"
                                                             IsChecked="{Binding IsCursorOverlayVisibilityWhileControlling, Mode=OneWay}"
                                                             Checked="CursorOverlayVisibilityWhileControlling_Checked"
                                                             Style="{StaticResource SegmentRadio}" />
                                            </UniformGrid>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,14,0,0" Text="Size" Style="{StaticResource DetailLabel}" />
                                            <UniformGrid Grid.Row="2" Grid.Column="1" Margin="0,14,0,0" Columns="3">
                                                <RadioButton Content="Small"
                                                             GroupName="CursorOverlaySize"
                                                             IsChecked="{Binding IsCursorOverlaySizeSmall, Mode=OneWay}"
                                                             Checked="CursorOverlaySizeSmall_Checked"
                                                             Style="{StaticResource SegmentRadio}" />
                                                <RadioButton Content="Medium"
                                                             GroupName="CursorOverlaySize"
                                                             IsChecked="{Binding IsCursorOverlaySizeMedium, Mode=OneWay}"
                                                             Checked="CursorOverlaySizeMedium_Checked"
                                                             Style="{StaticResource SegmentRadio}" />
                                                <RadioButton Content="Large"
                                                             GroupName="CursorOverlaySize"
                                                             IsChecked="{Binding IsCursorOverlaySizeLarge, Mode=OneWay}"
                                                             Checked="CursorOverlaySizeLarge_Checked"
                                                             Style="{StaticResource SegmentRadio}" />
                                            </UniformGrid>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,14,0,0" Text="Crosshairs" Style="{StaticResource DetailLabel}" />
                                            <CheckBox Grid.Row="3" Grid.Column="1" Margin="0,14,0,0"
                                                      Content="Show crosshairs"
                                                      Click="CursorOverlayCrosshairs_Click"
                                                      IsChecked="{Binding CursorOverlayCrosshairs, Mode=OneWay}" />

                                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,14,0,0" Text="Color" Style="{StaticResource DetailLabel}" />
                                            <WrapPanel Grid.Row="4" Grid.Column="1" Margin="0,14,0,0">
                                                <RadioButton AutomationProperties.Name="Red"
                                                             Width="104"
                                                             GroupName="CursorOverlayColor"
                                                             IsChecked="{Binding IsCursorOverlayColorRed, Mode=OneWay}"
                                                             Checked="CursorOverlayColorRed_Checked"
                                                             Style="{StaticResource SegmentRadio}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Border Width="12" Height="12" CornerRadius="6" Background="#D32F2F" />
                                                        <TextBlock Margin="6,0,0,0" Text="Red" />
                                                    </StackPanel>
                                                </RadioButton>
                                                <RadioButton AutomationProperties.Name="Green"
                                                             Width="104"
                                                             GroupName="CursorOverlayColor"
                                                             IsChecked="{Binding IsCursorOverlayColorGreen, Mode=OneWay}"
                                                             Checked="CursorOverlayColorGreen_Checked"
                                                             Style="{StaticResource SegmentRadio}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Border Width="12" Height="12" CornerRadius="6" Background="#84FF91" />
                                                        <TextBlock Margin="6,0,0,0" Text="Green" />
                                                    </StackPanel>
                                                </RadioButton>
                                                <RadioButton AutomationProperties.Name="Blue"
                                                             Width="104"
                                                             GroupName="CursorOverlayColor"
                                                             IsChecked="{Binding IsCursorOverlayColorBlue, Mode=OneWay}"
                                                             Checked="CursorOverlayColorBlue_Checked"
                                                             Style="{StaticResource SegmentRadio}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Border Width="12" Height="12" CornerRadius="6" Background="#64A6FF" />
                                                        <TextBlock Margin="6,0,0,0" Text="Blue" />
                                                    </StackPanel>
                                                </RadioButton>
                                                <RadioButton AutomationProperties.Name="Yellow"
                                                             Width="104"
                                                             GroupName="CursorOverlayColor"
                                                             IsChecked="{Binding IsCursorOverlayColorYellow, Mode=OneWay}"
                                                             Checked="CursorOverlayColorYellow_Checked"
                                                             Style="{StaticResource SegmentRadio}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Border Width="12" Height="12" CornerRadius="6" Background="#FFD166" />
                                                        <TextBlock Margin="6,0,0,0" Text="Yellow" />
                                                    </StackPanel>
                                                </RadioButton>
                                                <RadioButton AutomationProperties.Name="White"
                                                             Width="104"
                                                             GroupName="CursorOverlayColor"
                                                             IsChecked="{Binding IsCursorOverlayColorWhite, Mode=OneWay}"
                                                             Checked="CursorOverlayColorWhite_Checked"
                                                             Style="{StaticResource SegmentRadio}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Border Width="12" Height="12" CornerRadius="6" Background="#FFFFFF" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" />
                                                        <TextBlock Margin="6,0,0,0" Text="White" />
                                                    </StackPanel>
                                                </RadioButton>
                                            </WrapPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="UpdatesPanel" Visibility="Collapsed">
                        <Border Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="Updates" Style="{StaticResource SectionTitle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="Check for and install Switchify PC updates."
                                           Style="{StaticResource MutedText}" />
                                <Border Margin="0,16,0,0" Style="{StaticResource SubtlePanel}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding UpdateStatusMessage}" Style="{StaticResource DetailValue}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding UpdateDownloadMessage}"
                                                   Style="{StaticResource MutedText}" />
                                        <StackPanel Margin="0,10,0,0"
                                                    Visibility="{Binding IsUpdateDownloading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <ProgressBar Value="{Binding UpdateDownloadPercent, Mode=OneWay}"
                                                         IsIndeterminate="{Binding IsUpdateDownloadIndeterminate, Mode=OneWay}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding UpdateDownloadProgressText, Mode=OneWay}"
                                                       Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                        <WrapPanel Margin="0,14,0,0">
                                            <Button Content="{Binding UpdateCheckActionText}"
                                                    Margin="0,0,10,8"
                                                    Click="CheckForUpdates_Click"
                                                    IsEnabled="{Binding CanCheckForUpdates}"
                                                    Visibility="{Binding IsCheckUpdateActionVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="{Binding UpdatePrimaryActionText}"
                                                    Margin="0,0,10,8"
                                                    Click="InstallAvailableUpdate_Click"
                                                    Style="{StaticResource PrimaryButton}"
                                                    IsEnabled="{Binding CanRunUpdatePrimaryAction}"
                                                    Visibility="{Binding IsInstallUpdateActionVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="PrivacyPanel" Visibility="Collapsed">
                        <Border Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <TextBlock Text="Privacy" Style="{StaticResource SectionTitle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="Choose whether Switchify PC may send diagnostic information."
                                           Style="{StaticResource MutedText}" />
                                <Border Margin="0,16,0,0" Style="{StaticResource SubtlePanel}">
                                    <StackPanel>
                                        <CheckBox Content="Share diagnostic data"
                                                  Click="ShareDiagnosticData_Click"
                                                  IsChecked="{Binding ShareDiagnosticData, Mode=OneWay}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="Sends sanitized crashes, exceptions, and app health events. Typed text, commands, pairing secrets, device names, and full file paths are not sent. Turning this off deletes queued reports."
                                                   Style="{StaticResource MutedText}" />
                                        <Button Margin="0,14,0,0"
                                                HorizontalAlignment="Left"
                                                Content="Read privacy policy"
                                                Click="OpenPrivacyPolicy_Click" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
