<Window x:Class="SwitchifyPc.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Switchify PC"
        MinHeight="420"
        MinWidth="720"
        Height="520"
        Width="840">
    <Grid Background="#F6F7F9">
        <Border Margin="24"
                Padding="24"
                Background="White"
                BorderBrush="#D6DAE2"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Switchify PC"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#1F2937" />
                <TextBlock Margin="0,8,0,0"
                           Text="C# native app scaffold for the 0.2.0 migration."
                           FontSize="14"
                           Foreground="#4B5563" />
                <TextBlock Margin="0,18,0,0"
                           Text="This window is temporary while protocol, pairing, Bluetooth, input, tray, settings, startup, update, and packaging parity are ported."
                           FontSize="13"
                           Foreground="#6B7280"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
