<Window x:Class="SwitchifyPc.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:SwitchifyPc.Core.Ui;assembly=SwitchifyPc.Core"
        mc:Ignorable="d"
        Title="Switchify PC settings"
        MinHeight="560"
        MinWidth="720"
        Height="680"
        Width="860"
        d:DataContext="{d:DesignInstance Type=ui:SettingsViewModel, IsDesignTimeCreatable=True}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D6DAE2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5F6B7A" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <ScrollViewer Background="#F6F7F9">
        <StackPanel Margin="24" MaxWidth="860">
            <TextBlock Text="Settings"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#1F2937" />

            <Border Style="{StaticResource PanelBorder}" Margin="0,18,0,14">
                <StackPanel>
                    <TextBlock Text="General" Style="{StaticResource SectionTitle}" />
                    <CheckBox Margin="0,14,0,0"
                              Content="Start with system"
                              Click="StartWithSystem_Click"
                              IsChecked="{Binding StartWithSystem, Mode=OneWay}"
                              IsEnabled="{Binding StartWithSystemSupported}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding StartWithSystemMessage}"
                               Style="{StaticResource MutedText}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorder}">
                <StackPanel>
                    <TextBlock Text="Paired devices" Style="{StaticResource SectionTitle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding PairedDevicesMessage}"
                               Style="{StaticResource MutedText}" />
                    <ItemsControl Margin="0,12,0,0"
                                  ItemsSource="{Binding PairedDevices}"
                                  Visibility="{Binding HasPairedDevices, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        BorderBrush="#D6DAE2"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Background="#F9FAFB">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DeviceName}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#111827" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding DeviceId}"
                                                       Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Margin="16,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PairedAt, StringFormat=Paired {0}}"
                                                       Style="{StaticResource DetailValue}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding LastSeenAt, StringFormat=Last seen {0}}"
                                                       Style="{StaticResource MutedText}" />
                                            <Button Margin="0,8,0,0"
                                                    Padding="12,6"
                                                    HorizontalAlignment="Right"
                                                    Tag="{Binding DeviceId}"
                                                    Click="ForgetPairedDevice_Click"
                                                    Content="Forget" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorder}">
                <StackPanel>
                    <TextBlock Text="Pointer" Style="{StaticResource SectionTitle}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="Choose how Android pointer steps map to this display."
                               Style="{StaticResource MutedText}" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Scale" Style="{StaticResource DetailLabel}" />
                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="{Binding PointerScalePercent, StringFormat={}{0:0}%}" Style="{StaticResource DetailValue}" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="50%" Padding="12,6" Click="PointerScale50_Click" />
                                <Button Content="100%" Margin="8,0,0,0" Padding="12,6" Click="PointerScale100_Click" />
                                <Button Content="150%" Margin="8,0,0,0" Padding="12,6" Click="PointerScale150_Click" />
                                <Button Content="200%" Margin="8,0,0,0" Padding="12,6" Click="PointerScale200_Click" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Text="Small" Style="{StaticResource DetailLabel}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Text="{Binding PointerSmall}" Style="{StaticResource DetailValue}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" Text="Medium" Style="{StaticResource DetailLabel}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Text="{Binding PointerMedium}" Style="{StaticResource DetailValue}" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,0,0" Text="Large" Style="{StaticResource DetailLabel}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" Text="{Binding PointerLarge}" Style="{StaticResource DetailValue}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorder}">
                <StackPanel>
                    <TextBlock Text="Cursor overlay" Style="{StaticResource SectionTitle}" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Enabled" Style="{StaticResource DetailLabel}" />
                        <CheckBox Grid.Row="0" Grid.Column="1"
                                  Content="Show cursor overlay"
                                  Click="CursorOverlayEnabled_Click"
                                  IsChecked="{Binding CursorOverlayEnabled, Mode=OneWay}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Text="Size" Style="{StaticResource DetailLabel}" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="0,8,0,0"
                                  Width="180"
                                  HorizontalAlignment="Left"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding CursorOverlaySettings.Size, Mode=OneWay}"
                                  SelectionChanged="CursorOverlaySize_SelectionChanged">
                            <ComboBoxItem Content="Small" Tag="small" />
                            <ComboBoxItem Content="Medium" Tag="medium" />
                            <ComboBoxItem Content="Large" Tag="large" />
                        </ComboBox>
                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" Text="Visibility" Style="{StaticResource DetailLabel}" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="0,8,0,0"
                                  Width="180"
                                  HorizontalAlignment="Left"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding CursorOverlaySettings.Visibility, Mode=OneWay}"
                                  SelectionChanged="CursorOverlayVisibility_SelectionChanged">
                            <ComboBoxItem Content="On input" Tag="onInput" />
                            <ComboBoxItem Content="While controlling" Tag="whileControlling" />
                        </ComboBox>
                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,0,0" Text="Crosshairs" Style="{StaticResource DetailLabel}" />
                        <CheckBox Grid.Row="3"
                                  Grid.Column="1"
                                  Margin="0,8,0,0"
                                  Content="Show crosshairs"
                                  Click="CursorOverlayCrosshairs_Click"
                                  IsChecked="{Binding CursorOverlayCrosshairs, Mode=OneWay}" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,0,0" Text="Color" Style="{StaticResource DetailLabel}" />
                        <ComboBox Grid.Row="4"
                                  Grid.Column="1"
                                  Margin="0,8,0,0"
                                  Width="180"
                                  HorizontalAlignment="Left"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding CursorOverlaySettings.Color, Mode=OneWay}"
                                  SelectionChanged="CursorOverlayColor_SelectionChanged">
                            <ComboBoxItem Content="Red" Tag="red" />
                            <ComboBoxItem Content="Green" Tag="green" />
                            <ComboBoxItem Content="Blue" Tag="blue" />
                            <ComboBoxItem Content="Yellow" Tag="yellow" />
                            <ComboBoxItem Content="White" Tag="white" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorder}">
                <StackPanel>
                    <TextBlock Text="Updates" Style="{StaticResource SectionTitle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{Binding UpdateStatusMessage}"
                               Style="{StaticResource DetailValue}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding UpdateDownloadMessage}"
                               Style="{StaticResource MutedText}" />
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Content="Check for updates"
                                Padding="14,8"
                                Click="CheckForUpdates_Click" />
                        <Button Content="Download update"
                                Margin="10,0,0,0"
                                Padding="14,8"
                                Click="DownloadUpdate_Click"
                                IsEnabled="{Binding CanDownloadUpdate}" />
                        <Button Content="Install update"
                                Margin="10,0,0,0"
                                Padding="14,8"
                                Click="InstallUpdate_Click"
                                IsEnabled="{Binding CanInstallUpdate}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
